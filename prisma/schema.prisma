generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  password    String
  role        Role         @default(STAFF)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

model Member {
  id             String         @id @default(cuid())
  name           String
  email          String?        @unique
  phone          String?
  address        String?
  birthDate      DateTime?
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  memberships    Membership[]
  attendance     Attendance[]
  payments       Payment[]
  notifications  Notification[]
  memberRoutines MemberRoutine[]

  @@map("members")
}

model Plan {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  price       Float
  duration    Int
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]

  @@map("plans")
}

model Membership {
  id        String           @id @default(cuid())
  memberId  String
  planId    String
  userId    String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])
  plan      Plan             @relation(fields: [planId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@map("memberships")
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Payment {
  id           String        @id @default(cuid())
  memberId     String?
  membershipId String?
  amount       Float
  method       PaymentMethod @default(CASH)
  status       PaymentStatus @default(PENDING)
  notes        String?
  paidAt       DateTime?
  nextDueDate  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  member       Member?       @relation(fields: [memberId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model Attendance {
  id       String    @id @default(cuid())
  memberId String
  checkIn  DateTime  @default(now())
  checkOut DateTime?
  member   Member    @relation(fields: [memberId], references: [id])

  @@map("attendance")
}

model Notification {
  id          String              @id @default(cuid())
  memberId    String
  type        NotificationType
  channel     NotificationChannel
  title       String?
  message     String
  scheduledAt DateTime?
  dueDate     DateTime?
  sentAt      DateTime?
  status      NotificationStatus  @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  member      Member              @relation(fields: [memberId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  PAYMENT_REMINDER
  MEMBERSHIP_EXPIRY
  ATTENDANCE_STREAK
  ROUTINE_REMINDER
  CUSTOM
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model GymSettings {
  id                       String   @id @default("singleton")
  gymName                  String   @default("Mi Gimnasio")
  gymAddress               String?
  gymPhone                 String?
  gymEmail                 String?
  gymWebsite               String?
  gymLogoUrl               String?
  timezone                 String   @default("America/Argentina/Buenos_Aires")
  currency                 String   @default("ARS")
  currencySymbol           String   @default("$")
  locale                   String   @default("es-AR")
  dateFormat               String   @default("DD/MM/YYYY")
  defaultPlanDurationDays  Int      @default(30)
  gracePeriodDays          Int      @default(5)
  maxActiveMemberships     Int?
  defaultPaymentMethod     String   @default("CASH")
  paymentReminderDaysBefore Int     @default(3)
  enableAutoReminders      Boolean  @default(true)
  allowMultipleCheckinsPerDay Boolean @default(false)
  checkoutReminderHours    Int      @default(8)
  notificationChannels     String[] @default(["IN_APP"])
  openingTime              String?
  closingTime              String?
  openDays                 String[] @default(["MON", "TUE", "WED", "THU", "FRI", "SAT"])
  primaryColor             String   @default("#3b82f6")
  accentColor              String   @default("#1d4ed8")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("gym_settings")
}

model Equipment {
  id          String            @id @default(cuid())
  name        String            @unique
  category    EquipmentCategory
  description String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   Exercise[]

  @@map("equipment")
}

enum EquipmentCategory {
  BODYWEIGHT
  DUMBBELL
  BARBELL
  KETTLEBELL
  PLYOMETRIC_BOX
  ANKLE_WEIGHTS
  RESISTANCE_BAND
  OTHER
}

model Exercise {
  id               String             @id @default(cuid())
  name             String             @unique
  description      String?
  muscleGroup      MuscleGroup
  equipmentId      String?
  usesWeight       Boolean            @default(false)
  weightUnit       WeightUnit         @default(KG)
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  equipment        Equipment?         @relation(fields: [equipmentId], references: [id])
  routineExercises RoutineExercise[]
  sessionLogs      SessionExerciseLog[]

  @@map("exercises")
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  ARMS
  CORE
  LEGS
  GLUTES
  FULL_BODY
  CARDIO
}

enum WeightUnit {
  KG
  LB
  BODYWEIGHT
}

model Routine {
  id            String          @id @default(cuid())
  name          String
  description   String?
  objective     String?
  durationWeeks Int?
  active        Boolean         @default(true) @map("isActive")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  exercises     RoutineExercise[]
  assignments   MemberRoutine[]

  @@map("routines")
}

model RoutineExercise {
  id          String   @id @default(cuid())
  routineId   String
  exerciseId  String
  order       Int
  sets        Int
  reps        String
  restSeconds Int?
  notes       String?
  routine     Routine  @relation(fields: [routineId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])

  @@map("routine_exercises")
}

model MemberRoutine {
  id         String          @id @default(cuid())
  memberId   String
  routineId  String
  assignedAt DateTime        @default(now())
  startsAt   DateTime
  endsAt     DateTime?
  active     Boolean         @default(true)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  member     Member          @relation(fields: [memberId], references: [id])
  routine    Routine         @relation(fields: [routineId], references: [id])
  sessions   TrainingSession[]

  @@map("member_routines")
}

model TrainingSession {
  id              String               @id @default(cuid())
  memberRoutineId String
  sessionDate     DateTime             @default(now())
  durationMinutes Int?
  notes           String?
  completed       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  memberRoutine   MemberRoutine        @relation(fields: [memberRoutineId], references: [id])
  exerciseLogs    SessionExerciseLog[]

  @@map("training_sessions")
}

model SessionExerciseLog {
  id         String     @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int?
  weight     Float?
  weightUnit WeightUnit @default(KG)
  notes      String?
  createdAt  DateTime   @default(now())
  session    TrainingSession @relation(fields: [sessionId], references: [id])
  exercise   Exercise        @relation(fields: [exerciseId], references: [id])

  @@map("session_exercise_logs")
}
